    "components": {
        "schemas": {
            "AuthUser": {
                "required": [
                    "id",
                    "name",
                    "email",
                    "role"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Lahcen"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "lahcen@example.com"
                    },
                    "role": {
                        "type": "string",
                        "example": "member",
                        "enum": [
                            "admin",
                            "member"
                        ]
                    }
                },
                "type": "object"
            },
            "AuthorSummary": {
                "required": [
                    "id",
                    "name",
                    "initial"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Lahcen"
                    },
                    "initial": {
                        "type": "string",
                        "example": "L"
                    }
                },
                "type": "object"
            },
            "QuestionMetrics": {
                "required": [
                    "responses_count",
                    "favorites_count"
                ],
                "properties": {
                    "responses_count": {
                        "type": "integer",
                        "example": 4
                    },
                    "favorites_count": {
                        "type": "integer",
                        "example": 9
                    }
                },
                "type": "object"
            },
            "ResponseResource": {
                "required": [
                    "id",
                    "content",
                    "question_id",
                    "created_at",
                    "author",
                    "is_owner"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 12
                    },
                    "content": {
                        "type": "string",
                        "example": "You can find a pharmacy near the train station."
                    },
                    "question_id": {
                        "type": "integer",
                        "example": 5
                    },
                    "created_at": {
                        "type": "string",
                        "example": "2 minutes ago"
                    },
                    "author": {
                        "$ref": "#/components/schemas/AuthorSummary"
                    },
                    "is_owner": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "QuestionResource": {
                "required": [
                    "id",
                    "title",
                    "content",
                    "location",
                    "created_at",
                    "timestamp",
                    "author",
                    "metrics",
                    "responses"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 5
                    },
                    "title": {
                        "type": "string",
                        "example": "Where can I find a late-night pharmacy?"
                    },
                    "content": {
                        "type": "string",
                        "example": "I need a pharmacy open after 10pm in Casablanca."
                    },
                    "location": {
                        "type": "string",
                        "example": "Casablanca"
                    },
                    "created_at": {
                        "type": "string",
                        "example": "3 hours ago"
                    },
                    "timestamp": {
                        "type": "string",
                        "example": "10 Mar 2026 21:30"
                    },
                    "author": {
                        "$ref": "#/components/schemas/AuthorSummary"
                    },
                    "metrics": {
                        "$ref": "#/components/schemas/QuestionMetrics"
                    },
                    "responses": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ResponseResource"
                        }
                    }
                },
                "type": "object"
            },
            "ProfileStats": {
                "required": [
                    "questions_count",
                    "responses_count",
                    "favorites_count"
                ],
                "properties": {
                    "questions_count": {
                        "type": "integer",
                        "example": 7
                    },
                    "responses_count": {
                        "type": "integer",
                        "example": 16
                    },
                    "favorites_count": {
                        "type": "integer",
                        "example": 11
                    }
                },
                "type": "object"
            },
            "ProfileResource": {
                "required": [
                    "id",
                    "name",
                    "email",
                    "role",
                    "initial",
                    "joined_at",
                    "stats",
                    "recent_questions"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Lahcen"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "lahcen@example.com"
                    },
                    "role": {
                        "type": "string",
                        "example": "member",
                        "enum": [
                            "admin",
                            "member"
                        ]
                    },
                    "initial": {
                        "type": "string",
                        "example": "L"
                    },
                    "joined_at": {
                        "type": "string",
                        "example": "Mar 2026"
                    },
                    "stats": {
                        "$ref": "#/components/schemas/ProfileStats"
                    },
                    "recent_questions": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/QuestionResource"
                        }
                    }
                },
                "type": "object"
            },
            "AuthSuccessResponse": {
                "required": [
                    "token",
                    "user"
                ],
                "properties": {
                    "token": {
                        "type": "string",
                        "example": "1|sanctum-token-example"
                    },
                    "user": {
                        "$ref": "#/components/schemas/AuthUser"
                    }
                },
                "type": "object"
            },
            "RegisterSuccessResponse": {
                "required": [
                    "message",
                    "token",
                    "user"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "User registered successfully!!"
                    },
                    "token": {
                        "type": "string",
                        "example": "1|sanctum-token-example"
                    },
                    "user": {
                        "$ref": "#/components/schemas/AuthUser"
                    }
                },
                "type": "object"
            },
            "QuestionMutationResponse": {
                "required": [
                    "message",
                    "data"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Question created successfully!"
                    },
                    "data": {
                        "$ref": "#/components/schemas/QuestionResource"
                    }
                },
                "type": "object"
            },
            "ResponseMutationResponse": {
                "required": [
                    "message",
                    "data"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Intelligence contribution recorded."
                    },
                    "data": {
                        "$ref": "#/components/schemas/ResponseResource"
                    }
                },
                "type": "object"
            },
            "FavoriteToggleResponse": {
                "required": [
                    "message",
                    "is_favorited",
                    "favorites_count"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Question added to favorites !"
                    },
                    "is_favorited": {
                        "type": "boolean",
                        "example": true
                    },
                    "favorites_count": {
                        "type": "integer",
                        "example": 10
                    }
                },
                "type": "object"
            },
            "MessageResponse": {
                "required": [
                    "message"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Operation completed successfully."
                    }
                },
                "type": "object"
            },
            "ValidationErrorResponse": {
                "required": [
                    "message",
                    "errors"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "The given data was invalid."
                    },
                    "errors": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    }
                },
                "type": "object"
            },
            "UnauthorizedResponse": {
                "required": [
                    "message"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Unauthorized"
                    }
                },
                "type": "object"
            },
            "RegisterRequest": {
                "required": [
                    "name",
                    "email",
                    "password",
                    "device_name"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Lahcen",
                        "maxLength": 255,
                        "minLength": 3
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "lahcen@example.com"
                    },
                    "password": {
                        "type": "string",
                        "example": "secret123",
                        "minLength": 8
                    },
                    "device_name": {
                        "type": "string",
                        "example": "chrome"
                    },
                    "role": {
                        "type": "string",
                        "example": "member",
                        "nullable": true,
                        "enum": [
                            "admin",
                            "member"
                        ]
                    }
                },
                "type": "object"
            },
            "LoginRequest": {
                "required": [
                    "email",
                    "password",
                    "device_name"
                ],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "lahcen@example.com"
                    },
                    "password": {
                        "type": "string",
                        "example": "secret123"
                    },
                    "device_name": {
                        "type": "string",
                        "example": "chrome"
                    }
                },
                "type": "object"
            },
            "QuestionRequest": {
                "required": [
                    "title",
                    "content",
                    "location"
                ],
                "properties": {
                    "title": {
                        "type": "string",
                        "example": "Where can I repair my bike?",
                        "minLength": 5
                    },
                    "content": {
                        "type": "string",
                        "example": "Looking for a trusted bike repair shop near Maarif.",
                        "minLength": 10
                    },
                    "location": {
                        "type": "string",
                        "example": "Casablanca"
                    }
                },
                "type": "object"
            },
            "ResponseRequest": {
                "required": [
                    "content"
                ],
                "properties": {
                    "content": {
                        "type": "string",
                        "example": "There is one next to the central market.",
                        "maxLength": 2000,
                        "minLength": 5
                    }
                },
                "type": "object"
            },
            "PaginationLinks": {
                "properties": {
                    "first": {
                        "type": "string",
                        "example": "http://localhost:8080/api/questions?page=1",
                        "nullable": true
                    },
                    "last": {
                        "type": "string",
                        "example": "http://localhost:8080/api/questions?page=2",
                        "nullable": true
                    },
                    "prev": {
                        "type": "string",
                        "nullable": true
                    },
                    "next": {
                        "type": "string",
                        "example": "http://localhost:8080/api/questions?page=2",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "PaginationMetaLink": {
                "required": [
                    "url",
                    "label",
                    "active"
                ],
                "properties": {
                    "url": {
                        "type": "string",
                        "example": "http://localhost:8080/api/questions?page=1",
                        "nullable": true
                    },
                    "label": {
                        "type": "string",
                        "example": "1"
                    },
                    "active": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "PaginationMeta": {
                "required": [
                    "current_page",
                    "from",
                    "last_page",
                    "links",
                    "path",
                    "per_page",
                    "to",
                    "total"
                ],
                "properties": {
                    "current_page": {
                        "type": "integer",
                        "example": 1
                    },
                    "from": {
                        "type": "integer",
                        "example": 1,
                        "nullable": true
                    },
                    "last_page": {
                        "type": "integer",
                        "example": 3
                    },
                    "links": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/PaginationMetaLink"
                        }
                    },
                    "path": {
                        "type": "string",
                        "example": "http://localhost:8080/api/questions"
                    },
                    "per_page": {
                        "type": "integer",
                        "example": 15
                    },
                    "to": {
                        "type": "integer",
                        "example": 15,
                        "nullable": true
                    },
                    "total": {
                        "type": "integer",
                        "example": 31
                    }
                },
                "type": "object"
            },
            "QuestionPaginatedResponse": {
                "required": [
                    "data",
                    "links",
                    "meta"
                ],
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/QuestionResource"
                        }
                    },
                    "links": {
                        "$ref": "#/components/schemas/PaginationLinks"
                    },
                    "meta": {
                        "$ref": "#/components/schemas/PaginationMeta"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Use the bearer token returned by the register or login endpoint.",
                "bearerFormat": "Token",
                "scheme": "bearer"
            }
        }
