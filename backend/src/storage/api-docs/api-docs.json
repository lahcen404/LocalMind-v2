                                    "$ref": "#/components/schemas/QuestionResource"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Question not found"
                    }
                }
            },
            "put": {
                "tags": [
                    "Questions"
                ],
                "summary": "Update a question",
                "operationId": "899bb44a229896a3cd8f916e7c4ac34c",
                "parameters": [
                    {
                        "name": "question",
                        "in": "path",
                        "description": "Question id",
                        "required": true,
